<?xml version="1.0" encoding="utf-8"?>
<!-- Skippy home-screen widget — dark navy glass card with last AI response + quick actions -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp"
    android:gravity="center_vertical">

    <!-- Header row: icon + title + live badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@mipmap/ic_launcher_round"
            android:contentDescription="Skippy" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Skippy"
            android:textColor="#FF29C2E6"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/widget_ai_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI"
            android:textColor="#FFEAB308"
            android:textSize="9sp"
            android:background="@drawable/widget_badge_bg"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Last AI response snippet -->
    <TextView
        android:id="@+id/widget_response"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Ask Skippy anything…"
        android:textColor="#BFCFE8"
        android:textSize="12sp"
        android:maxLines="3"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.3" />

    <!-- Action buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:weightSum="2">

        <!-- New Chat -->
        <TextView
            android:id="@+id/widget_btn_new_chat"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:background="@drawable/widget_btn_cyan"
            android:gravity="center"
            android:text="💬  New Chat"
            android:textColor="#FF29C2E6"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Open Home -->
        <TextView
            android:id="@+id/widget_btn_home"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:background="@drawable/widget_btn_ghost"
            android:gravity="center"
            android:text="🏠  Home"
            android:textColor="#80A0C0"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>

