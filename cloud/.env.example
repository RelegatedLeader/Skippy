# ── Skippy Cloud Environment Variables ───────────────────────────────────────
# Copy this to .env when deploying to Railway (or any cloud host).
# Set all values in Railway's dashboard under "Variables".

# ─── AI Keys (same as local) ──────────────────────────────────────────────────
GROK_API_KEY=your_grok_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Auth (MUST change) ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=REPLACE_WITH_A_RANDOM_64_CHAR_STRING

# ─── Database ─────────────────────────────────────────────────────────────────
# Railway PostgreSQL — add the PostgreSQL plugin in your Railway project,
# then copy the DATABASE_URL it provides here.
# Change prisma/schema.prisma provider to "postgresql" for cloud builds.
DATABASE_URL=postgresql://user:password@host:5432/skippy

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
