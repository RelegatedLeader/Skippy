{
  "buildCommand": "npx prisma generate --schema=cloud/schema.cloud.prisma && npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "BUILD_STANDALONE": "0"
  },
  "crons": [
    {
      "path": "/api/cron/daily-brief",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/nudge",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/memory-reflect",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/memory-consolidate",
      "schedule": "0 4 * * 0"
    }
  ]
}
